{
  "name": "ayurveda-herb-traceability",
  "version": "1.0.0",
  "description": "Blockchain-based Ayurvedic herb traceability system",
  "scripts": {
    "test:blockchain": "node test-blockchain.js",
    "test:e2e": "node test-e2e.js",
    "test:all": "npm run test:blockchain && npm run test:e2e",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "demo:setup": "echo '🚀 Starting Demo Setup...' && npm run dev:all"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "keywords": [
    "blockchain",
    "traceability",
    "ayurveda",
    "avalanche",
    "hackathon"
  ],
  "author": "SIH 2025 Team",
  "license": "MIT"
}
